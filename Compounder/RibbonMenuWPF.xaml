<UserControl
    x:Class="Compounder.RibbonMenuWPF"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:local="clr-namespace:Compounder"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    d:DesignHeight="450"
    d:DesignWidth="1200"
    mc:Ignorable="d">
    <Grid>

        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition />
        </Grid.RowDefinitions>
        <Ribbon x:Name="RibbonWin" SelectedIndex="0">
            <Ribbon.HelpPaneContent>
                <RibbonButton
                    x:Name="HelpButton"
                    Click="HelpButton_Click"
                    SmallImageSource="Icons\question.png" />
            </Ribbon.HelpPaneContent>
            <Ribbon.ApplicationMenu>
                <RibbonApplicationMenu Visibility="Collapsed" />
            </Ribbon.ApplicationMenu>
            <Ribbon.QuickAccessToolBar>
                <RibbonQuickAccessToolBar Visibility="Collapsed" />
            </Ribbon.QuickAccessToolBar>
            <RibbonTab
                x:Name="projectTab"
                Header="Project"
                KeyTip="H">
                <!--  Home  group  -->
                <RibbonGroup x:Name="General" Header="General">
                    <RibbonToggleButton
                        KeyTip="X"
                        Label="Selection"
                        SmallImageSource="Icons/cursor.ico" />
                    <RibbonButton
                        KeyTip="F"
                        Label="Fit all"
                        SmallImageSource="Icons/magnifier.ico" />
                    <RibbonButton Label="Undo" SmallImageSource="Icons/arrow-curve-180-left.ico" />




                </RibbonGroup>





                <RibbonGroup x:Name="layout" Header="Layout ">
                    <RibbonButton
                        Click="RibbonButton_Click"
                        KeyTip="B"
                        Label="Automatic"
                        SmallImageSource="Icons/application-tile.png" />
                    <RibbonButton
                        KeyTip="S"
                        Label="Spring"
                        SmallImageSource="Icons/molecule.png" />

                </RibbonGroup>
                <RibbonGroup x:Name="data" Header="Data ">
                    <RibbonButton
                        Click="ImportImage_click"
                        KeyTip="B"
                        Label="Import image"
                        SmallImageSource="Icons/image-sunset.png" />

                </RibbonGroup>




                <RibbonGroup x:Name="settings" Header="Settings ">
                    <RibbonButton Label="Settings" SmallImageSource="Icons/gear.png" />
                </RibbonGroup>

            </RibbonTab>



        </Ribbon>
    </Grid>
</UserControl>
